{
  "name": "packref",
  "version": "0.0.0",
  "description": "Local, versioned package references for your agents",
  "keywords": [
    "agents",
    "cli",
    "dependencies",
    "npm",
    "reference",
    "source"
  ],
  "homepage": "https://github.com/adelrodriguez/packref#readme",
  "bugs": {
    "url": "https://github.com/adelrodriguez/packref/issues"
  },
  "license": "MIT",
  "author": "Adel Rodríguez",
  "repository": {
    "type": "git",
    "url": "https://github.com/adelrodriguez/packref.git"
  },
  "bin": {
    "packref": "bin/packref"
  },
  "files": [
    "bin",
    "dist"
  ],
  "type": "module",
  "imports": {
    "#*": "./src/*"
  },
  "scripts": {
    "analyze": "adamantite analyze",
    "build": "bunup",
    "bump:deps": "bun update --interactive",
    "check": "adamantite check",
    "dev": "bunup --watch",
    "fix": "adamantite fix",
    "format": "adamantite format",
    "init": "bun run --bun scripts/init.ts",
    "release": "changeset publish",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "test:watch": "bun test --watch",
    "typecheck": "tsc --noEmit",
    "version": "changeset version && bun run format"
  },
  "dependencies": {
    "@effect/platform-node": "4.0.0-beta.56",
    "effect": "4.0.0-beta.56"
  },
  "devDependencies": {
    "@changesets/cli": "2.29.8",
    "@clack/prompts": "1.0.1",
    "@types/bun": "1.3.9",
    "adamantite": "^0.32.1",
    "bunup": "0.16.29",
    "knip": "6.6.1",
    "oxfmt": "0.46.0",
    "oxlint": "1.61.0",
    "oxlint-tsgolint": "0.21.1",
    "typescript": "^5.9.3"
  },
  "packageManager": "bun@1.3.1"
}
